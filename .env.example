# eBay API Configuration
# Copy this file to .env.local and fill in your credentials

# Get these from: https://developer.ebay.com/my/keys
VITE_EBAY_CLIENT_ID=your_client_id_here
VITE_EBAY_CLIENT_SECRET=your_client_secret_here

# OAuth redirect URI (must match your eBay app RuName)
VITE_EBAY_REDIRECT_URI=http://localhost:8080/auth/ebay/callback

# Environment: 'sandbox' for testing, 'production' for live
VITE_EBAY_ENVIRONMENT=sandbox

# Refresh token (auto-filled after OAuth authentication)
VITE_EBAY_REFRESH_TOKEN=
